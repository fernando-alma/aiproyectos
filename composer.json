{
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "*",
        "guzzlehttp/guzzle": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Models\\": "frontend/models/",
            "App\\Backend\\Controllers\\": "backend/app/Controllers/",
            "App\\Backend\\Models\\": "backend/app/Models/",
            "App\\Backend\\": "backend/app/",
            "App\\Frontend\\": "frontend/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
